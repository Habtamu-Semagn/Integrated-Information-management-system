{
  "name": "startup-backend-system",
  "version": "1.0.0",
  "description": "Startup Backend System - Node.js/Express modular monolith with JWT authentication and MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "seed": "node scripts/seed.js",
    "seed:fresh": "node scripts/seed.js --fresh",
    "db:clear": "node scripts/clear.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "express",
    "mongodb",
    "jwt",
    "authentication",
    "rest-api",
    "modular-monolith"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-validator": "^7.3.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.1",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "fast-check": "^4.7.0",
    "jest": "^29.0.0",
    "mongodb-memory-server": "^9.0.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "supertest": "^6.3.0"
  }
}
